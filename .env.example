# ---------------------------------------------------------------------------
# Analytics Chat Assistant — environment template
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored; this template is committed so the required vars are documented.
# ---------------------------------------------------------------------------

# Which LLM provider to use: "anthropic" or "openai".
# The provider abstraction (src/lib/llm/providers) reads this at runtime.
LLM_PROVIDER=anthropic

# API keys — only the selected provider's key is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (sensible defaults are used if left blank).
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# PostgreSQL connections (two roles — see README §4 "Two database roles").
# Defaults match the docker-compose Postgres set up in step 2.
# ---------------------------------------------------------------------------

# Read-only role: used to run LLM-generated SQL against the analytics tables.
DATABASE_URL_READONLY=postgres://aca_readonly:readonly_pw@localhost:5432/analytics

# App role: used to read/write chat history (the `messages` table).
DATABASE_URL_APP=postgres://aca_app:app_pw@localhost:5432/analytics
