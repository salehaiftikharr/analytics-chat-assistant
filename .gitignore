# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — ignore everything except the committed template
.env*
!.env.example

# vercel
.vercel

# assessment brief — keep out of the public repo
superorgs-take-home-assessment.pdf
*.pdf

# typescript
*.tsbuildinfo
next-env.d.ts
